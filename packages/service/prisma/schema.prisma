generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  banned        Boolean?     @default(false)
  banReason     String?
  banExpires    DateTime?
  flags         String[]     @default([])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  invitations   Invitation[]
  uploads       Upload[]
  userRoles     UserRole[]

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String    @id @default(cuid())
  expiresAt            DateTime
  token                String
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy       String?
  activeOrganizationId String?
  revokedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String
  logo        String?
  metadata    String?
  createdAt   DateTime
  members     Member[]
  invitations Invitation[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  inviterId      String
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model SystemConfig {
  id          String   @id @default(cuid())
  group       String
  key         String
  value       String
  type        String   @default("string")
  label       String
  description String?
  isSecret    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([group, key])
  @@index([group])
  @@map("system_config")
}

model Upload {
  id         String   @id @default(cuid())
  path       String
  mimeType   String
  size       Int
  visibility String   @default("private")
  uploaderId String
  uploader   User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([uploaderId])
  @@map("upload")
}

enum LinkType {
  GROUP
  INTERNAL
  EXTERNAL
}

model Application {
  id          String       @id @default(cuid())
  name        String
  code        String
  description String?
  logo        String?
  sortOrder   Int          @default(0)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  menus       Menu[]
  roles       Role[]
  permissions Permission[]

  @@unique([code])
  @@index([deletedAt])
  @@map("application")
}

model Menu {
  id           String     @id @default(cuid())
  appId        String
  app          Application @relation(fields: [appId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       Menu?      @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     Menu[]     @relation("MenuTree")
  name         String
  code         String
  icon         String?
  linkType     LinkType   @default(GROUP)
  url          String?
  sortOrder    Int        @default(0)
  permissionId String     @unique
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([appId])
  @@index([parentId])
  @@map("menu")
}

model Permission {
  id              String           @id @default(cuid())
  appId           String
  app             Application      @relation(fields: [appId], references: [id], onDelete: Cascade)
  name            String
  code            String
  group           String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  menu            Menu?

  @@unique([appId, code])
  @@index([group])
  @@index([appId])
  @@map("permission")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permission")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_role")
}

model Role {
  id              String           @id @default(cuid())
  appId           String
  app             Application      @relation(fields: [appId], references: [id], onDelete: Cascade)
  name            String
  code            String
  flags           String[]         @default([])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([appId, code])
  @@index([appId])
  @@map("role")
}

model OperationLog {
  id           String   @id @default(cuid())
  traceId      String
  sessionId    String?
  level        String   @default("info")
  source       String?
  module       String?
  event        String
  message      String?
  method       String?
  path         String?
  statusCode   Int?
  durationMs   Int?
  errorName    String?
  errorMessage String?
  stack        String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([traceId])
  @@index([sessionId])
  @@index([level])
  @@index([module])
  @@index([event])
  @@index([statusCode])
  @@index([createdAt])
  @@map("operation_log")
}

model AuditLog {
  id         String   @id @default(cuid())
  traceId    String
  sessionId  String?
  userId     String?
  userName   String?
  event      String
  category   String
  severity   String   @default("info")
  outcome    String   @default("success")
  targetType String?
  targetId   String?
  targetName String?
  before     Json?
  after      Json?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([traceId])
  @@index([sessionId])
  @@index([userId])
  @@index([event])
  @@index([category])
  @@index([severity])
  @@index([outcome])
  @@index([createdAt])
  @@map("audit_log")
}
