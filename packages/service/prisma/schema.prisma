generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  banned        Boolean?     @default(false)
  banReason     String?
  banExpires    DateTime?
  flags         String[]     @default([])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  invitations   Invitation[]
  uploads       Upload[]
  roleAssignments RoleAssignment[]
  notifications Notification[]

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String    @id @default(cuid())
  expiresAt            DateTime
  token                String
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy       String?
  activeOrganizationId String?
  revokedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String
  logo        String?
  metadata    String?
  createdAt   DateTime
  members     Member[]
  invitations Invitation[]
  departments Department[]
  positions   Position[]

  @@unique([slug])
  @@map("organization")
}

model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentId       String?
  parent         Department?  @relation("DepartmentTree", fields: [parentId], references: [id], onDelete: Cascade)
  children       Department[] @relation("DepartmentTree")
  name           String
  code           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  members        Member[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([parentId])
  @@map("department")
}

model Position {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  code           String
  description    String?
  sortOrder      Int              @default(0)
  roleId         String?          @unique
  role           Role?            @relation(fields: [roleId], references: [id], onDelete: SetNull)
  memberPositions MemberPosition[]
  createdAt      DateTime         @default(now())

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("position")
}

model MemberPosition {
  id         String   @id @default(cuid())
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([memberId, positionId])
  @@index([memberId])
  @@index([positionId])
  @@map("member_position")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  memberPositions MemberPosition[]
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  inviterId      String
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model SystemConfig {
  id          String   @id @default(cuid())
  group       String
  key         String
  value       String
  type        String   @default("string")
  schema      Json?
  label       String
  description String?
  isSecret    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([group, key])
  @@index([group])
  @@map("system_config")
}

model Upload {
  id         String   @id @default(cuid())
  path       String
  mimeType   String
  size       Int
  visibility String   @default("private")
  uploaderId String
  uploader   User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([uploaderId])
  @@index([path])
  @@map("upload")
}

enum LinkType {
  GROUP
  INTERNAL
  EXTERNAL
}

enum RoleScopeType {
  PLATFORM
  ORGANIZATION
  APPLICATION
}

model Application {
  id          String       @id @default(cuid())
  name        String
  code        String
  description String?
  logo        String?
  favicon     String?
  copyright   String?
  icp         String?
  psif        String?
  watermarkEnabled Boolean @default(false)
  watermarkConfig  String?
  sortOrder   Int          @default(0)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  menus        Menu[]
  roles        Role[]
  permissions  Permission[]
  notifications Notification[]

  @@unique([code])
  @@index([deletedAt])
  @@map("application")
}

model Menu {
  id           String     @id @default(cuid())
  appId        String
  app          Application @relation(fields: [appId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       Menu?      @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     Menu[]     @relation("MenuTree")
  name         String
  code         String
  icon         String?
  linkType     LinkType        @default(GROUP)
  url          String?
  sortOrder    Int             @default(0)
  menuPermissions MenuPermission[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([appId])
  @@index([parentId])
  @@map("menu")
}

model MenuPermission {
  id           String     @id @default(cuid())
  menuId       String
  menu         Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([menuId, permissionId])
  @@index([menuId])
  @@index([permissionId])
  @@map("menu_permission")
}

model Permission {
  id              String           @id @default(cuid())
  appId           String?
  app             Application?     @relation(fields: [appId], references: [id], onDelete: Cascade)
  name            String
  code            String
  group           String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  menuPermissions MenuPermission[]

  @@unique([appId, code])
  @@index([group])
  @@index([appId])
  @@map("permission")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permission")
}

model RoleAssignment {
  id        String        @id @default(cuid())
  userId    String
  roleId    String
  role      Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopeType RoleScopeType @default(PLATFORM)
  scopeId   String        @default("")
  createdAt DateTime      @default(now())

  @@unique([userId, roleId, scopeType, scopeId])
  @@index([userId])
  @@index([roleId])
  @@index([scopeType, scopeId])
  @@map("role_assignment")
}

model Role {
  id              String           @id @default(cuid())
  appId           String
  app             Application      @relation(fields: [appId], references: [id], onDelete: Cascade)
  scopeType       RoleScopeType    @default(PLATFORM)
  scopeId         String           @default("")
  name            String
  code            String
  flags           String[]         @default([])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  roleAssignments RoleAssignment[]
  position        Position?

  @@unique([appId, scopeType, scopeId, code])
  @@index([appId])
  @@index([scopeType, scopeId])
  @@map("role")
}

model OperationLog {
  id           String   @id @default(cuid())
  traceId      String
  sessionId    String?
  level        String   @default("info")
  source       String?
  module       String?
  event        String
  message      String?
  method       String?
  path         String?
  statusCode   Int?
  durationMs   Int?
  errorName    String?
  errorMessage String?
  stack        String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([traceId])
  @@index([sessionId])
  @@index([level])
  @@index([module])
  @@index([event])
  @@index([statusCode])
  @@index([createdAt])
  @@map("operation_log")
}

model AuditLog {
  id         String   @id @default(cuid())
  traceId    String
  sessionId  String?
  userId     String?
  userName   String?
  event      String
  category   String
  severity   String   @default("info")
  outcome    String   @default("success")
  targetType String?
  targetId   String?
  targetName String?
  before     Json?
  after      Json?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([traceId])
  @@index([sessionId])
  @@index([userId])
  @@index([event])
  @@index([category])
  @@index([severity])
  @@index([outcome])
  @@index([createdAt])
  @@map("audit_log")
}

model NotificationChannel {
  id          String    @id @default(cuid())
  key         String
  name        String
  providerKey String
  enabled     Boolean   @default(true)
  config      Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  templates     NotificationTemplate[]
  notifications Notification[]

  @@unique([key])
  @@index([providerKey])
  @@index([enabled])
  @@index([deletedAt])
  @@map("notification_channel")
}

model NotificationTemplate {
  id              String              @id @default(cuid())
  key             String
  channelId       String
  channel         NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  enabled         Boolean             @default(true)
  subjectTemplate String?
  titleTemplate   String?
  bodyTemplate    String
  variablesSchema Json?
  sampleVariables Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  notifications Notification[]

  @@unique([key])
  @@index([channelId])
  @@index([enabled])
  @@index([deletedAt])
  @@map("notification_template")
}

model Notification {
  id                String               @id @default(cuid())
  correlationId     String
  templateId        String
  template          NotificationTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  channelId         String
  channel           NotificationChannel  @relation(fields: [channelId], references: [id], onDelete: Restrict)
  recipientUserId   String
  recipient         User                 @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)
  appId             String?
  app               Application?         @relation(fields: [appId], references: [id], onDelete: Cascade)
  creatorId         String?
  source            String?
  variables         Json?
  renderedSubject   String?
  renderedTitle     String?
  renderedBody      String
  status            String               @default("pending")
  attempts          Int                  @default(0)
  nextAttemptAt     DateTime?
  sentAt            DateTime?
  failedAt          DateTime?
  readAt            DateTime?
  archivedAt        DateTime?
  providerMessageId String?
  errorMessage      String?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([correlationId])
  @@index([templateId])
  @@index([channelId])
  @@index([recipientUserId])
  @@index([appId])
  @@index([status])
  @@index([createdAt])
  @@map("notification")
}
