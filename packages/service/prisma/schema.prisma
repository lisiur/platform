generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean      @default(false)
  avatar        String?
  avatarId      String?
  banned        Boolean?     @default(false)
  banReason     String?
  banExpires    DateTime?
  flags         String[]     @default([])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  invitations   Invitation[]
  roleAssignments RoleAssignment[]
  notifications       Notification[]
  createdNotifications Notification[] @relation("NotificationCreator")
  apiTokens           ApiToken[]
  attachments     Attachment[] @relation("AttachmentCreator")

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String    @id @default(cuid())
  expiresAt            DateTime
  token                String
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?
  revokedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("session")
}

model Account {
  id           String   @id @default(cuid())
  accountId    String
  providerId   String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerData Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum JobPriority {
  CRITICAL
  HIGH
  NORMAL
  LOW
  IDLE
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model JobInstance {
  id          String      @id @default(cuid())
  jobId       String?
  job         Job?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  type        String
  description String?
  payload     Json
  status      JobStatus   @default(PENDING)
  priority    JobPriority @default(NORMAL)
  result      Json?
  error       String?
  attempts    Int         @default(0)
  maxAttempts Int         @default(3)
  timeoutMs   Int         @default(60000)
  scheduledAt DateTime    @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([jobId])
  @@index([status, scheduledAt])
  @@index([status, priority])
  @@index([type])
  @@index([completedAt])
  @@map("job_instance")
}

model Job {
  id             String       @id @default(cuid())
  name           String       @unique
  type           String
  description    String?
  payload        Json?
  cronExpression String?
  enabled        Boolean      @default(true)
  priority       JobPriority  @default(NORMAL)
  maxAttempts    Int          @default(3)
  timeoutMs      Int          @default(60000)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  instances      JobInstance[]

  @@index([enabled, nextRunAt])
  @@map("job")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String
  logo        String?
  logoId      String?
  createdAt   DateTime
  updatedAt   DateTime     @updatedAt
  members     Member[]
  invitations Invitation[]
  departments Department[]
  positions   Position[]
  apiTokens   ApiToken[]

  @@unique([slug])
  @@map("organization")
}

model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentId       String?
  parent         Department?  @relation("DepartmentTree", fields: [parentId], references: [id], onDelete: Cascade)
  children       Department[] @relation("DepartmentTree")
  name           String
  code           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  members        Member[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([parentId])
  @@map("department")
}

model Position {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  code           String
  description    String?
  sortOrder      Int              @default(0)
  roleId         String?          @unique
  role           Role?            @relation(fields: [roleId], references: [id], onDelete: SetNull)
  memberPositions MemberPosition[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("position")
}

model MemberPosition {
  id         String   @id @default(cuid())
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([memberId, positionId])
  @@index([memberId])
  @@index([positionId])
  @@map("member_position")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId     String?
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  memberPositions MemberPosition[]
  createdAt      DateTime
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([departmentId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  inviterId      String
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([inviterId])
  @@map("invitation")
}

model SystemConfig {
  id          String   @id @default(cuid())
  group       String
  key         String
  value       String
  type        String   @default("string")
  schema      Json?
  label       String
  description String?
  isSecret    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([group, key])
  @@index([group])
  @@map("system_config")
}

model Upload {
  id         String   @id @default(cuid())
  path       String
  mimeType   String
  size       Int
  hash       String   @unique
  createdAt  DateTime @default(now())

  attachments Attachment[]

  @@index([path])
  @@map("upload")
}

model Attachment {
  id         String   @id @default(cuid())
  bizType    String
  bizId      String
  uploadId   String
  upload     Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  visibility String   @default("private")
  createdBy  String
  creator    User     @relation("AttachmentCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([bizType, bizId])
  @@index([uploadId])
  @@index([createdBy])
  @@map("attachment")
}

enum LinkType {
  GROUP
  INTERNAL
  EXTERNAL
}

model Application {
  id          String       @id @default(cuid())
  name        String
  code        String
  description String?
  logo        String?
  logoId      String?
  favicon     String?
  faviconId   String?
  copyright   String?
  icp         String?
  psif        String?
  watermarkEnabled Boolean @default(false)
  watermarkConfig  String?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  menus        Menu[]
  roles        Role[]
  permissions  Permission[]
  notifications Notification[]
  apiTokens    ApiToken[]

  @@unique([code])
  @@map("application")
}

model Menu {
  id           String     @id @default(cuid())
  appId        String
  app          Application @relation(fields: [appId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       Menu?      @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     Menu[]     @relation("MenuTree")
  name         String
  code         String
  icon         String?
  linkType     LinkType        @default(GROUP)
  url          String?
  sortOrder    Int             @default(0)
  menuPermissions MenuPermission[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([appId])
  @@index([parentId])
  @@map("menu")
}

model MenuPermission {
  id           String     @id @default(cuid())
  menuId       String
  menu         Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([menuId, permissionId])
  @@index([menuId])
  @@index([permissionId])
  @@map("menu_permission")
}

model Permission {
  id              String           @id @default(cuid())
  appId           String
  app             Application      @relation(fields: [appId], references: [id], onDelete: Cascade)
  name            String
  code            String
  group           String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  menuPermissions MenuPermission[]

  @@unique([appId, code])
  @@index([group])
  @@index([appId])
  @@map("permission")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permission")
}

model RoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope     String
  createdAt DateTime @default(now())

  @@unique([userId, roleId, scope])
  @@index([userId])
  @@index([roleId])
  @@index([scope])
  @@map("role_assignment")
}

model Role {
  id              String           @id @default(cuid())
  appId           String
  app             Application      @relation(fields: [appId], references: [id], onDelete: Cascade)
  scope           String
  name            String
  code            String
  flags           String[]         @default([])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  roleAssignments RoleAssignment[]
  position        Position?

  @@unique([appId, scope, code])
  @@index([appId])
  @@index([scope])
  @@map("role")
}

model OperationLog {
  id           String   @id @default(cuid())
  traceId      String
  authType     String?
  authTokenId  String?
  level        String   @default("info")
  source       String?
  module       String?
  event        String
  message      String?
  method       String?
  path         String?
  statusCode   Int?
  durationMs   Int?
  errorName    String?
  errorMessage String?
  stack        String?
  metadata     Json?
  ip           String?
  isSsr        Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([traceId])
  @@index([authType])
  @@index([authTokenId])
  @@index([level])
  @@index([module])
  @@index([event])
  @@index([statusCode])
  @@index([isSsr])
  @@index([createdAt])
  @@map("operation_log")
}

model AuditLog {
  id          String   @id @default(cuid())
  traceId     String
  authType    String?
  authTokenId String?
  userId      String?
  userName    String?
  source      String?
  event       String
  category    String
  severity    String   @default("info")
  outcome     String   @default("success")
  before      Json?
  after       Json?
  metadata    Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([traceId])
  @@index([authType])
  @@index([authTokenId])
  @@index([userId])
  @@index([event])
  @@index([category])
  @@index([severity])
  @@index([outcome])
  @@index([createdAt])
  @@map("audit_log")
}

model NotificationChannel {
  id          String    @id @default(cuid())
  key         String
  name        String
  providerKey String
  enabled     Boolean   @default(true)
  config      Json?
  flags       String[] @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  templates     NotificationTemplate[]
  notifications Notification[]

  @@unique([key])
  @@index([providerKey])
  @@index([enabled])
  @@map("notification_channel")
}

model NotificationTemplate {
  id              String              @id @default(cuid())
  key             String
  channelId       String
  channel         NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  enabled         Boolean             @default(true)
  subjectTemplate String?
  titleTemplate   String?
  bodyTemplate    String
  variablesSchema Json?
  sampleVariables Json?
  flags           String[]           @default([])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  notifications Notification[]

  @@unique([key])
  @@index([channelId])
  @@index([enabled])
  @@map("notification_template")
}

model Notification {
  id                String               @id @default(cuid())
  correlationId     String
  templateId        String
  template          NotificationTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  channelId         String
  channel           NotificationChannel  @relation(fields: [channelId], references: [id], onDelete: Restrict)
  recipientUserId   String
  recipient         User                 @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)
  appId             String?
  app               Application?         @relation(fields: [appId], references: [id], onDelete: Cascade)
  creatorId         String?
  creator           User?                @relation("NotificationCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  source            String?
  variables         Json?
  renderedSubject   String?
  renderedTitle     String?
  renderedBody      String
  status            NotificationStatus   @default(PENDING)
  attempts          Int                  @default(0)
  nextAttemptAt     DateTime?
  sentAt            DateTime?
  failedAt          DateTime?
  readAt            DateTime?
  archivedAt        DateTime?
  providerMessageId String?
  errorMessage      String?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([correlationId])
  @@index([templateId])
  @@index([channelId])
  @@index([recipientUserId])
  @@index([appId])
  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
  @@map("notification")
}

model RateLimitOverride {
  id        String    @id @default(cuid())
  subject   String    @unique
  type      String
  max       Int?
  windowMs  Int?
  bypass    Boolean   @default(false)
  note      String?
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([type])
  @@map("rate_limit_override")
}

model ApiToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  tokenPrefix String
  tokenSuffix String @default("")
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  scopes    String[] @default([])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appId      String?
  app        Application? @relation(fields: [appId], references: [id], onDelete: Cascade)
  enabled    Boolean  @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  lastUsedIp String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ownerId])
  @@index([organizationId])
  @@map("api_token")
}

