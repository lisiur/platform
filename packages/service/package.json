{
  "name": "@repo/service",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "imports": {
    "#extractors/*": "./src/extractors/*.ts",
    "#generated/*": "./prisma/generated/*.ts",
    "#lib/*": "./src/lib/*.ts",
    "#middleware/*": "./src/middleware/*.ts",
    "#repositories/*": "./src/repositories/*.ts",
    "#routes/*": "./src/routes/*.ts",
    "#services/*": "./src/services/*.ts",
    "#states": "./src/states/index.ts",
    "#states/*": "./src/states/*.ts",
    "#utils/*": "./src/utils/*.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "db:reset": "prisma migrate reset",
    "db:reset:danger": "node scripts/reset-danger.mjs",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@hono/zod-openapi": "^1.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@repo/shared": "workspace:*",
    "@scalar/hono-api-reference": "^0.10.14",
    "argon2": "^0.44.0",
    "hono": "^4.0.0",
    "nodemailer": "^6.9.0",
    "pg": "^8.20.0",
    "p-queue": "^8.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.40",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "^4.1.6"
  }
}
