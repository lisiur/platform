# Copy this file to .env.production and fill in real values.
# .env.production is gitignored and read by ecosystem.config.cjs (PM2).

# Deploy runbook: npm install && npm run migrate && npm run start
# Redeploy:      npm run migrate && npm run reload

# --- Database (required) ---
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/platform

# --- App SSR API origin (required) ---
# Server-side (RSC/SSR) calls from the admin/organization apps reach the gateway
# here. Single-host PM2/nginx layout → the gateway on 127.0.0.1:3000.
API_ORIGIN=http://127.0.0.1:3000

# --- CORS (required in production) ---
# Comma-separated list of allowed origins. In production the service fails
# closed (no cross-origin allowed) when this is unset.
CORS_ALLOWED_ORIGINS=https://your-domain.com

# --- Uploads (required for private file operations) ---
UPLOAD_SIGN_SECRET=replace-with-a-long-random-string

# --- Optional: rate limiting ---
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_GLOBAL_MAX=300
# RATE_LIMIT_GLOBAL_WINDOW_MS=60000
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_AUTH_WINDOW_MS=60000

# --- Optional: jobs & cache ---
# JOB_CONCURRENCY=5
# CACHE_MAX_SIZE=1000

# --- Optional: boot-time seeding ---
# The service self-seeds reference data (permissions, menus, roles, ...) on
# boot. Idempotent and safe to run repeatedly. Set to false to skip.
# SEED_ON_BOOT=false
